{
  "name": "auto-blogging-system",
  "version": "1.0.0",
  "description": "Advanced auto blogging system with multi-platform publishing",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "setup": "npm install && npm run setup:db --workspace=server",
    "setup:db": "npm run db:migrate --workspace=server && npm run db:seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
